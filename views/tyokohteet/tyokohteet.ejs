<!DOCTYPE html>
<html lang="fi">
<%- include('../partials/head') %>

<body>
    <div class="content-wrapper">
        <%- include('../partials/header') %>
        <%- include('../partials/nav') %>

        <main class="container">
            <div class="page-header">
                <h2>Työkohteet</h2>
            </div>

            <table class="data-table">
                <thead>
                    <tr>
                        <th>Tunnus</th>
                        <th>Nimi</th>
                        <th>Osoite</th>
                        <th>Omistaja</th>
                    </tr>
                </thead>
                <tbody>
                    <% tyokohteet.forEach(tyokohde => { %>
                        <tr>
                            <td><strong><%= tyokohde.tyokohde_id %></strong></td>
                            <td><%= tyokohde.nimi %></td>
                            <td><%= tyokohde.osoite %></td>
                            <td>
                                <a href="/asiakkaat/<%= tyokohde.asiakas_id %>" class="customer-link">
                                    <%= tyokohde.asiakas_nimi || 'Avaa asiakas' %>
                                </a>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </main>
    </div>
    <%- include('../partials/footer') %>
</body>
</html>