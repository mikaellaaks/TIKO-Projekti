<!DOCTYPE html>
<html lang="fi">
<%- include('../partials/head') %>
<body>
    <div class="content-wrapper">
        <%- include('../partials/header') %>
        <%- include('../partials/nav') %>

        <main class="container">
            <div class="breadcrumb">
                <a href="/tyokohteet/<%= tyokohde.id %>">← Takaisin kohteeseen</a>
            </div>

            <div class="page-header">
                <h2>Hinta-arvio</h2>
                <p><strong>Kohde:</strong> <%= tyokohde.nimi %> | <strong>Osoite:</strong> <%= tyokohde.osoite %></p>
            </div>

            <div class="grid-container">
                <section class="info-card">
                    <h3>Työ ja tarvikkeet</h3>
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Nimike</th>
                                <th>Määrä</th>
                                <th>Hinta (alv 0%)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% tulos.tuntirivit.forEach(rivi => { %>
                                <tr>
                                    <td>Työ: <%= rivi.nimi %></td>
                                    <td><%= rivi.maara %> h</td>
                                    <td><%= rivi.hinta.toFixed(2) %> €</td>
                                </tr>
                            <% }) %>
                            <% tulos.tarvikerivit.forEach(rivi => { %>
                                <tr>
                                    <td><%= rivi.nimi %></td>
                                    <td><%= rivi.maara %> kpl</td>
                                    <td><%= rivi.hinta.toFixed(2) %> €</td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </section>

                <section class="info-card summary-card">
                    <h3>Kustannusarvio yhteensä</h3>
                    <div class="summary-line">
                        <span>Välisumma (alv 0%):</span>
                        <strong><%= (tulos.tyo_yhteensa + tulos.tarvike_yhteensa).toFixed(2) %> €</strong>
                    </div>
                    <div class="summary-line">
                        <span>ALV 24%:</span>
                        <strong><%= tulos.alv.toFixed(2) %> €</strong>
                    </div>
                    <div class="summary-line total">
                        <span><strong>Loppusumma:</strong></span>
                        <span class="price-tag"><%= tulos.kokonaissumma.toFixed(2) %> €</span>
                    </div>
                    
                    <% if (tulos.kotitalousvahennys > 0) { %>
                        <div class="highlight-box">
                            <small>Kotitalousvähennyskelpoinen työn osuus: <%= tulos.kotitalousvahennys.toFixed(2) %> €</small>
                        </div>
                    <% } %>
                </section>
            </div>
        </main>
    </div>
    <%- include('../partials/footer') %>
</body>
</html>