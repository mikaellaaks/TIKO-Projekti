<!DOCTYPE html>
<html lang="fi">
<%- include('../partials/head') %>

    <body>
        <div class="content-wrapper">
            <%- include('../partials/header') %>
                <%- include('../partials/nav') %>

                    <main class="container">
                        <div class="page-header">
                            <h2>Toimittajat</h2>
                            <button id="openModal" class="btn-primary">+ Lisää uusi toimittaja</button>
                        </div>

                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Tunnus</th>
                                    <th>Nimi</th>
                                    <th>Toiminnot</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% toimittajat.forEach(toimittaja=> { %>
                                    <tr>
                                        <td><strong>
                                                <%= toimittaja.toimittaja_id %>
                                            </strong></td>
                                        <td>
                                            <%= toimittaja.nimi %>
                                        </td>
                                        <td>
                                            <form action="/toimittajat/poista/<%= toimittaja.toimittaja_id %>" method="POST"
                                                style="display: inline;"
                                                onsubmit="return confirm('Haluatko varmasti poistaa tämän toimittajan?')">
                                                <input type="hidden" name="toimittaja_id"
                                                    value="<%= toimittaja.toimittaja_id %>">
                                                <button type="submit" class="btn-primary btn-delete">Poista</button>
                                            </form>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>

                        <div id="customerModal" class="modal">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h3>Lisää uusi toimittaja</h3>
                                    <span class="close-btn">&times;</span>
                                </div>
                                <form action="/toimittajat/lisaa" method="POST">
                                    <div class="form-grid">
                                        <div class="form-group">
                                            <label>Nimi</label>
                                            <input type="text" name="nimi" required>
                                        </div>
                                    </div>
                                    <div class="form-actions">
                                        <button type="button" class="btn-primary btn-cancel close-btn">Peruuta</button>
                                        <button type="submit" class="btn-primary">Tallenna toimittaja</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </main>
        </div>
        <%- include('../partials/footer') %>
    </body>
    <script>
        const modal = document.getElementById("customerModal");
        const openBtn = document.getElementById("openModal");
        const closeBtns = document.querySelectorAll(".close-btn");

        // Avaa ikkuna
        openBtn.onclick = () => modal.style.display = "block";

        // Sulje ikkuna ruksista tai peruuta-namiskasta
        closeBtns.forEach(btn => {
            btn.onclick = () => modal.style.display = "none";
        });
    </script>

</html>