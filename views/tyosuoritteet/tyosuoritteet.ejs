<!DOCTYPE html>
<html lang="fi">
<%- include('../partials/head') %>

    <body>
        <div class="content-wrapper">
            <%- include('../partials/header') %>
                <%- include('../partials/nav') %>

                    <main class="container">
                        <div class="page-header">
                            <h2>Työsuoritteet</h2>
                        </div>

                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Asiakas</th>
                                    <th>Työkohde</th>
                                    <th>Osoite</th>
                                    <th>Laskutustyyppi</th>
                                    <th>Tilaus id</th>
                                    <th>Toiminnot</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% tyosuoritteet.forEach(ts => { %>
                                    <tr>
                                        <td><strong><%= ts.tyosuorite_id %></strong></td>
                                        <td><%= ts.asiakas_nimi %></td>
                                        <td><%= ts.tyokohde_nimi %></td>
                                        <td><%= ts.tyokohde_osoite %></td>
                                        <td><%= ts.tyyppi === 'tunti' ? 'Tuntityö' : 'Urakka' %></td>
                                        <td><%= ts.lasku_id ? 'Lasku: ' + ts.lasku_id : (ts.urakkasopimus_id ? 'Urakka: ' + ts.urakkasopimus_id : '-') %></td>
                                        <td>
                                            <button onclick="location.href='/tyosuoritteet/<%= ts.tyosuorite_id %>'" class="btn-primary btn-edit">Tarkastele/Kirjaa</button>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </main>
        </div>
        <%- include('../partials/footer') %>
    </body>
</html>