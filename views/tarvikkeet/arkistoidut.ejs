<!DOCTYPE html>
<html lang="fi">
<%- include('../partials/head') %>

    <body>
        <div class="content-wrapper">
            <%- include('../partials/header') %>
                <%- include('../partials/nav') %>

                    <main class="container">
                        <div class="page-header">
                            <h2>Arkistoidut tarvikkeet</h2>
                        </div>

                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Tunnus</th>
                                    <th>Nimi</th>
                                    <th>Merkki</th>
                                    <th>Yksikkö</th>
                                    <th>Ostohinta</th>
                                    <th>Myyntihinta</th>
                                    <th>Toimittaja</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% tarvikkeet.forEach(tarvike_historia=> { %>
                                    <tr>
                                        <td><strong>
                                                <%= tarvike_historia.tarvike_id %>
                                            </strong></td>
                                        <td>
                                            <%= tarvike_historia.nimi %>
                                        </td>
                                        <td>
                                            <%= tarvike_historia.merkki %>
                                        </td>
                                        <td>
                                            <%= tarvike_historia.yksikko %>
                                        </td>
                                        <td>
                                            €<%= Number(tarvike_historia.sisaanostohinta).toFixed(2) %>
                                        </td>
                                        <td>
                                            €<%= Number(tarvike_historia.myyntihinta).toFixed(2) %>
                                        </td>
                                        <td>
                                            <%= tarvike_historia.toimittaja_nimi || 'Ei määritetty' %>
                                        </td>
                                        <td>
                                            <form action="/tarvikkeet/arkistoi/<%= tarvike.tarvike_id %>"
                                                method="POST" style="display: inline;"
                                                onsubmit="return confirm('Haluatko varmasti arkistoida tämän tarvikkeen?')">
                                                <input type="hidden" name="tarvike_id"
                                                    value="<%= tarvike.tarvike_id %>">
                                                <button type="submit" class="btn-primary btn-delete">Arkistoi</button>
                                            </form>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>

                        <div id="customerModal" class="modal">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h3>Lisää uusi tarvike</h3>
                                    <span class="close-btn">&times;</span>
                                </div>
                                <form action="/tarvikkeet/lisaa" method="POST">
                                    <div class="form-grid">
                                        <div class="form-group">
                                            <label>Nimi</label>
                                            <input type="text" name="nimi" required>
                                        </div>
                                        <div class="form-group">
                                            <label>Osoite</label>
                                            <input type="text" name="osoite" required>
                                        </div>
                                        <div class="form-group">
                                            <label>Sähköposti</label>
                                            <input type="email" name="email" required>
                                        </div>
                                        <div class="form-group">
                                            <label>Puhelinnumero</label>
                                            <input type="text" name="puhelinnumero" required>
                                        </div>
                                    </div>
                                    <div class="form-actions">
                                        <button type="button" class="btn-primary btn-cancel close-btn">Peruuta</button>
                                        <button type="submit" class="btn-primary">Tallenna tarvike</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </main>
        </div>
        <%- include('../partials/footer') %>
    </body>
    <script>
        const modal = document.getElementById("customerModal");
        const openBtn = document.getElementById("openModal");
        const closeBtns = document.querySelectorAll(".close-btn");

        // Avaa ikkuna
        openBtn.onclick = () => modal.style.display = "block";

        // Sulje ikkuna ruksista tai peruuta-namiskasta
        closeBtns.forEach(btn => {
            btn.onclick = () => modal.style.display = "none";
        });
    </script>

</html>