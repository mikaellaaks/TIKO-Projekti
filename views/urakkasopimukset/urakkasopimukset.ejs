<!DOCTYPE html>
<html lang="fi">
<%- include('../partials/head') %>

    <body>
        <div class="content-wrapper">
            <%- include('../partials/header') %>
                <%- include('../partials/nav') %>

                    <main class="container">
                        <div class="page-header">
                            <h2>Urakkasopimukset</h2>
                            <button id="openModal" class="btn-primary">+ Lisää uusi urakka</button>
                        </div>

                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Tunnus</th>
                                    <th>Asiakas</th>
                                    <th>Työkohde</th>
                                    <th>Päivämäärä</th>
                                    <th>Suunnittelutunnit</th>
                                    <th>Työtunnit</th>
                                    <th>Hyväksytty</th>
                                    <th>Toiminnot</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% urakkasopimukset.forEach(urakka=> { %>
                                    <tr>
                                        <td>
                                            <%= urakka.urakkasopimus_id %>
                                        </td>
                                        <td>
                                            <%= urakka.asiakas_nimi %>
                                        </td>
                                        <td>
                                            <%= urakka.tyokohde_nimi %>
                                        </td>
                                        <td>
                                            <%= new Date(urakka.luotu_pvm).toLocaleDateString('fi-FI') %>
                                        </td>
                                        <td>
                                            <%= urakka.suunnittelu_tunnit %> h
                                        </td>
                                        <td>
                                            <%= urakka.tyo_tunnit %> h
                                        </td>
                                        <td>
                                            <%= urakka.hyvaksytty ? 'Kyllä' : 'Ei' %>
                                        </td>
                                        <td><button onclick="window.location.href='/urakkasopimukset/<%= urakka.urakkasopimus_id %>/tarjous'"
                                                class="btn-primary">Näytä tarjous</button></td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>

                        <div id="customerModal" class="modal">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h3>Lisää uusi urakkasopimus</h3>
                                    <span class="close-btn">&times;</span>
                                </div>
                                <form action="/urakkasopimukset/lisaa" method="POST">
                                    <div class="form-grid">
                                        <div class="form-group">
                                            <label>Asiakas</label>
                                            <select name="asiakas_id" id="asiakasSelect" required>
                                                <option value="" disabled selected>Valitse asiakas...</option>
                                                <% (locals.asiakkaat || []).forEach(asiakas=> { %>
                                                    <option value="<%= asiakas.asiakas_id %>">
                                                        <%= asiakas.nimi %>
                                                    </option>
                                                    <% }) %>
                                            </select>
                                        </div>

                                        <div class="form-group">
                                            <label>Työkohde</label>
                                            <select name="tyokohde_id" id="tyokohdeSelect" required>
                                                <option value="" disabled selected>Valitse työkohde...</option>
                                                </option>
                                                <% (locals.tyokohteet || []).forEach(kohde=> { %>
                                                    <option value="<%= kohde.tyokohde_id %>"
                                                        data-asiakas="<%= kohde.asiakas_id %>">
                                                        <%= kohde.nimi %> (<%= kohde.osoite %>)
                                                    </option>
                                                    <% }) %>
                                            </select>
                                        </div>
                                        <div class="form-group">
                                            <label>Suunnittelutunnit</label>
                                            <input type="number" name="suunnittelu_tunnit" required>
                                        </div>
                                        <div class="form-group">
                                            <label>Työtunnit</label>
                                            <input type="number" name="tyo_tunnit" required>
                                        </div>
                                        <div class="form-group">
                                            <label>Alennusprosentti</label>
                                            <input type="number" name="alennus_prosentti" value="10" required>
                                        </div>
                                    </div>
                                    <div class="form-actions">
                                        <button type="button" class="btn-primary btn-cancel close-btn">Peruuta</button>
                                        <button type="submit" class="btn-primary">Tallenna urakka</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                        <script>
                            const asiakasSelect = document.getElementById('asiakasSelect');
                            const tyokohdeSelect = document.getElementById('tyokohdeSelect');
                            const tyokohdeOptions = Array.from(tyokohdeSelect.options);

                            asiakasSelect.addEventListener('change', function () {
                                const valittuAsiakasId = this.value;

                                // Aktivoidaan työkohde-valikko
                                tyokohdeSelect.disabled = false;

                                // Nollataan aiempi valinta
                                tyokohdeSelect.value = "";

                                // Suodatetaan näkyvyys
                                tyokohdeOptions.forEach(option => {
                                    const kohdeAsiakasId = option.getAttribute('data-asiakas');

                                    // Näytetään vain valitun asiakkaan kohteet (ja pidetään tyhjä oletusvaihtoehto)
                                    if (!kohdeAsiakasId || kohdeAsiakasId === valittuAsiakasId) {
                                        option.style.display = "block";
                                        option.disabled = false;
                                    } else {
                                        option.style.display = "none";
                                        option.disabled = true;
                                    }
                                });

                                // Muutetaan ohjeteksti
                                tyokohdeSelect.options[0].textContent = "Valitse työkohde...";
                            });
                        </script>
                    </main>
        </div>
        <%- include('../partials/footer') %>
    </body>
    <script>
        const modal = document.getElementById("customerModal");
        const openBtn = document.getElementById("openModal");
        const closeBtns = document.querySelectorAll(".close-btn");

        // Avaa ikkuna
        openBtn.onclick = () => modal.style.display = "block";

        // Sulje ikkuna ruksista tai peruuta-namiskasta
        closeBtns.forEach(btn => {
            btn.onclick = () => modal.style.display = "none";
        });
    </script>

</html>