<!DOCTYPE html>
<html lang="fi">
<%- include('../partials/head') %>

    <body>
        <div class="content-wrapper">
            <%- include('../partials/header') %>
                <%- include('../partials/nav') %>

                    <main class="container">
                        <% if (locals.message) { %>
                            <div style="background-color: #2ecc71; color: white; padding: 15px; border-radius: 5px; margin-bottom: 20px; font-weight: bold; text-align: center;">
                                <%= message %>
                            </div>
                        <% } %>
                        <div class="page-header">
                            <h2>Laskut</h2>
                            <div>
                                <button id="openModal" class="btn-primary">+ Lisää uusi lasku</button>
                                <form action="/laskut/muistutukset" method="POST" style="display:inline;">
                                    <button type="submit" class="btn-primary" style="background-color: #e74c3c;">Luo muistutuslaskut erääntyneistä</button>
                                </form>
                            </div>
                        </div>

                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Tunnus</th>
                                    <th>Asiakas</th>
                                    <th>Työkohde</th>
                                    <th>Päivämäärä</th>
                                    <th>Eräpäivä</th>
                                    <th>Summa</th>
                                    <th>Maksettu</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                <% laskut.forEach(lasku=> { %>
                                    <tr>
                                        <td><strong>
                                                <%= lasku.lasku_id %>
                                            </strong></td>
                                        <td>
                                            <%= lasku.asiakas_nimi %>
                                        </td>
                                        <td>
                                            <%= lasku.tyokohde_nimi %>
                                        </td>
                                        <td>
                                            <%= lasku.paivamaara ? lasku.paivamaara.toLocaleDateString() : '' %>
                                        </td>
                                        <td>
                                            <%= lasku.erapaiva ? lasku.erapaiva.toLocaleDateString() : '' %>
                                        </td>
                                        <td>
                                            €<%= lasku.kokonaissumma ? Number(lasku.kokonaissumma).toFixed(2) : '0.00'
                                                %>
                                        </td>
                                        <td>
                                            <% if (!lasku.maksettu) { %>
                                                <form action="/laskut/maksettu/<%= lasku.lasku_id %>" method="POST"
                                                    style="display:inline;">
                                                    <button type="submit" class="btn-primary btn-edit">Merkitse
                                                        maksetuksi</button>
                                                </form>
                                                <% } else { %>
                                                    <span class="status-paid">Maksettu</span>
                                                    <% } %>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>

                        <!-- Modal uuden laskun luomiseen -->
                        <div id="customerModal" class="modal" style="display: none; position: fixed; z-index: 1; left: 0; top: 0; width: 100%; height: 100%; overflow: auto; background-color: rgba(0,0,0,0.4);">
                            <div class="modal-content" style="background-color: #fefefe; margin: 15% auto; padding: 20px; border: 1px solid #888; width: 50%; border-radius: 5px;">
                                <span class="close-btn" style="color: #aaa; float: right; font-size: 28px; font-weight: bold; cursor: pointer;">&times;</span>
                                <h3>Lisää uusi lasku</h3>
                                <form action="/laskut/lisaa" method="POST" style="display: flex; flex-direction: column; gap: 10px; margin-top: 15px;">
                                    <label>Asiakas</label>
                                    <select name="asiakas_id" required>
                                        <option value="">Ladataan asiakkaita...</option>
                                        <% (locals.asiakkaat || []).forEach(asiakas => { %>
                                            <option value="<%= asiakas.asiakas_id %>"><%= asiakas.nimi %></option>
                                        <% }) %>
                                    </select>
                                    
                                    <label>Työkohde</label>
                                    <select name="tyokohde_id" required>
                                        <option value="">Ladataan työkohteita...</option>
                                        <% (locals.tyokohteet || []).forEach(kohde => { %>
                                            <option value="<%= kohde.tyokohde_id %>" data-asiakas="<%= kohde.asiakas_id %>"><%= kohde.nimi %> (<%= kohde.osoite %>)</option>
                                        <% }) %>
                                    </select>

                                    <script>
                                        // Filter tyokohteet based on selected asiakas
                                        document.querySelector('select[name="asiakas_id"]').addEventListener('change', function() {
                                            const asiakasId = this.value;
                                            const tyokohdeSelect = document.querySelector('select[name="tyokohde_id"]');
                                            const tyokohteet = Array.from(tyokohdeSelect.options);
                                            
                                            tyokohteet.forEach(option => {
                                                if (option.value === "") return;
                                                if (option.getAttribute('data-asiakas') === asiakasId) {
                                                    option.style.display = '';
                                                } else {
                                                    option.style.display = 'none';
                                                }
                                            });
                                            tyokohdeSelect.value = "";
                                        });
                                    </script>

                                    <label>Kokonaissumma</label>
                                    <input type="number" step="0.01" name="kokonaissumma" required>
                                    
                                    <label>Päivämäärä</label>
                                    <input type="date" name="paivamaara" required>
                                    
                                    <label>Eräpäivä</label>
                                    <input type="date" name="erapaiva" required>
                                    
                                    <label>Tila</label>
                                    <select name="tila">
                                        <option value="valmis">Valmis</option>
                                        <option value="kesken">Kesken</option>
                                    </select>
                                    
                                    <label>Laskunro</label>
                                    <input type="number" name="laskunro" value="1" required>

                                    <div style="margin-top: 15px; display: flex; gap: 10px;">
                                        <button type="submit" class="btn-primary">Tallenna</button>
                                        <button type="button" class="btn-primary close-btn" style="background-color: #95a5a6;">Peruuta</button>
                                    </div>
                                </form>
                            </div>
                        </div>

                    </main>
        </div>
        <%- include('../partials/footer') %>
    </body>
    <script>
        const modal = document.getElementById("customerModal");
        const openBtn = document.getElementById("openModal");
        const closeBtns = document.querySelectorAll(".close-btn");

        // Avaa ikkuna
        openBtn.onclick = () => modal.style.display = "block";

        // Sulje ikkuna ruksista tai peruuta-namiskasta
        closeBtns.forEach(btn => {
            btn.onclick = () => modal.style.display = "none";
        });
    </script>

</html>