<!DOCTYPE html>
<html lang="fi">
<%- include('../partials/head') %>

    <body>
        <div class="content-wrapper">
            <%- include('../partials/header') %>
                <%- include('../partials/nav') %>

                    <main class="container">
                        <% if (locals.message) { %>
                            <div
                                style="background-color: #2ecc71; color: white; padding: 15px; border-radius: 5px; margin-bottom: 20px; font-weight: bold; text-align: center;">
                                <%= message %>
                            </div>
                            <% } %>
                                <div class="page-header">
                                    <h2>Laskut</h2>
                                    <div>
                                        <button id="openModal" class="btn-primary">+ Lisää uusi lasku</button>
                                        <form action="/laskut/muistutukset" method="POST" style="display:inline;">
                                            <button type="submit" class="btn-primary"
                                                style="background-color: #e74c3c;">Luo muistutuslaskut
                                                erääntyneistä</button>
                                        </form>
                                    </div>
                                </div>

                                <table class="data-table">
                                    <thead>
                                        <tr>
                                            <th>Tunnus</th>
                                            <th>Asiakas</th>
                                            <th>Työkohde</th>
                                            <th>Päivämäärä</th>
                                            <th>Eräpäivä</th>
                                            <th>Summa</th>
                                            <th>Maksettu</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% laskut.forEach(lasku=> { %>
                                            <tr>
                                                <td><strong>
                                                        <%= lasku.lasku_id %>
                                                    </strong></td>
                                                <td>
                                                    <%= lasku.asiakas_nimi %>
                                                </td>
                                                <td>
                                                    <%= lasku.tyokohde_nimi %>
                                                </td>
                                                <td>
                                                    <%= lasku.paivamaara ? lasku.paivamaara.toLocaleDateString() : '' %>
                                                </td>
                                                <td>
                                                    <%= lasku.erapaiva ? lasku.erapaiva.toLocaleDateString() : '' %>
                                                </td>
                                                <td>
                                                    €<%= lasku.kokonaissumma ? Number(lasku.kokonaissumma).toFixed(2)
                                                        : '0.00' %>
                                                </td>
                                                <td>
                                                    <% if (!lasku.maksettu) { %>
                                                        <form action="/laskut/maksettu/<%= lasku.lasku_id %>"
                                                            method="POST" style="display:inline;">
                                                            <button type="submit" class="btn-primary btn-edit">Merkitse
                                                                maksetuksi</button>
                                                        </form>
                                                        <% } else { %>
                                                            <span class="status-paid">Maksettu</span>
                                                            <% } %>
                                                </td>
                                                <td>
                                                    <button
                                                        onclick="window.location.href='/laskut/<%= lasku.lasku_id %>'"
                                                        class="btn-primary btn-edit">Näytä
                                                        lasku</button>
                                                </td>
                                            </tr>
                                            <% }) %>
                                    </tbody>
                                </table>

                                <!-- Modal uuden laskun luomiseen -->
                                <div id="customerModal" class="modal">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h3>Lisää uusi lasku</h3>
                                            <span class="close-btn">&times;</span>
                                        </div>
                                        <form action="/laskut/lisaa" method="POST">
                                            <div class="form-grid">
                                                <div class="form-group">
                                                    <label>Asiakas</label>
                                                    <select name="asiakas_id" id="asiakasSelect" required>
                                                        <option value="" disabled selected>Valitse asiakas...</option>
                                                        <% (locals.asiakkaat || []).forEach(asiakas=> { %>
                                                            <option value="<%= asiakas.asiakas_id %>">
                                                                <%= asiakas.nimi %>
                                                            </option>
                                                            <% }) %>
                                                    </select>
                                                </div>

                                                <div class="form-group">
                                                    <label>Työkohde</label>
                                                    <select name="tyokohde_id" id="tyokohdeSelect" required>
                                                        <option value="" disabled selected>Valitse työkohde...</option>
                                                        </option>
                                                        <% (locals.tyokohteet || []).forEach(kohde=> { %>
                                                            <option value="<%= kohde.tyokohde_id %>"
                                                                data-asiakas="<%= kohde.asiakas_id %>">
                                                                <%= kohde.nimi %> (<%= kohde.osoite %>)
                                                            </option>
                                                            <% }) %>
                                                    </select>
                                                </div>

                                                <div class="form-group">
                                                    <label>Kokonaissumma (€)</label>
                                                    <input type="number" step="0.01" name="kokonaissumma"
                                                        placeholder="0.00" required>
                                                </div>

                                                <div class="form-group">
                                                    <label>Laskun numero</label>
                                                    <input type="number" name="laskunro" value="1" required>
                                                </div>

                                                <div class="form-group">
                                                    <label>Päivämäärä</label>
                                                    <input type="date" name="paivamaara" id="defaultDate" required>
                                                </div>

                                                <div class="form-group">
                                                    <label>Eräpäivä</label>
                                                    <input type="date" name="erapaiva" id="defaultDue" required>
                                                </div>

                                                <div class="form-group">
                                                    <label>Tila</label>
                                                    <select name="tila">
                                                        <option value="valmis">Valmis</option>
                                                        <option value="kesken">Kesken</option>
                                                    </select>
                                                </div>
                                            </div>

                                            <div class="form-actions">
                                                <button type="button"
                                                    class="btn-primary btn-cancel close-btn">Peruuta</button>
                                                <button type="submit" class="btn-primary">Tallenna lasku</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>

                                <script>
                                    document.getElementById('asiakasSelect').addEventListener('change', function () {
                                        const asiakasId = this.value;
                                        const tyokohdeSelect = document.getElementById('tyokohdeSelect');
                                        const options = tyokohdeSelect.querySelectorAll('option');

                                        tyokohdeSelect.value = "";

                                        options.forEach(option => {
                                            if (option.disabled) return;

                                            if (option.getAttribute('data-asiakas') === asiakasId) {
                                                option.style.display = 'block';
                                            } else {
                                                option.style.display = 'none';
                                            }
                                        });
                                    });

                                    // Asetetaan oletuspäivämäärät (tämä päivä ja +14 vrk)
                                    const today = new Date().toISOString().split('T')[0];
                                    const dueDate = new Date();
                                    dueDate.setDate(dueDate.getDate() + 14);
                                    const dueStr = dueDate.toISOString().split('T')[0];

                                    document.getElementById('defaultDate').value = today;
                                    document.getElementById('defaultDue').value = dueStr;
                                </script>

                    </main>
        </div>
        <%- include('../partials/footer') %>
    </body>
    <script>
        const modal = document.getElementById("customerModal");
        const openBtn = document.getElementById("openModal");
        const closeBtns = document.querySelectorAll(".close-btn");

        // Avaa ikkuna
        openBtn.onclick = () => modal.style.display = "block";

        // Sulje ikkuna ruksista tai peruuta-namiskasta
        closeBtns.forEach(btn => {
            btn.onclick = () => modal.style.display = "none";
        });
    </script>

</html>