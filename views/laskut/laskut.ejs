<!DOCTYPE html>
<html lang="fi">
<%- include('../partials/head') %>

    <body>
        <div class="content-wrapper">
            <%- include('../partials/header') %>
                <%- include('../partials/nav') %>

                    <main class="container">
                        <div class="page-header">
                            <h2>Laskut</h2>
                        </div>

                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Tunnus</th>
                                    <th>Asiakas</th>
                                    <th>Työkohde</th>
                                    <th>Päivämäärä</th>
                                    <th>Eräpäivä</th>
                                    <th>Summa</th>
                                    <th>Maksettu</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                <% laskut.forEach(lasku=> { %>
                                    <tr>
                                        <td><strong>
                                                <%= lasku.lasku_id %>
                                            </strong></td>
                                        <td>
                                            <%= lasku.asiakas_nimi %>
                                        </td>
                                        <td>
                                            <%= lasku.tyokohde_nimi %>
                                        </td>
                                        <td>
                                            <%= lasku.paivamaara ? lasku.paivamaara.toLocaleDateString() : '' %>
                                        </td>
                                        <td>
                                            <%= lasku.erapaiva ? lasku.erapaiva.toLocaleDateString() : '' %>
                                        </td>
                                        <td>
                                            €<%= lasku.kokonaissumma ? Number(lasku.kokonaissumma).toFixed(2) : '0.00'
                                                %>
                                        </td>
                                        <td>
                                            <% if (!lasku.maksettu) { %>
                                                <form action="/laskut/maksettu/<%= lasku.lasku_id %>" method="POST"
                                                    style="display:inline;">
                                                    <button type="submit" class="btn-primary btn-edit">Merkitse
                                                        maksetuksi</button>
                                                </form>
                                                <% } else { %>
                                                    <span class="status-paid">Maksettu</span>
                                                    <% } %>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </main>
        </div>
        <%- include('../partials/footer') %>
    </body>
    <script>
        const modal = document.getElementById("customerModal");
        const openBtn = document.getElementById("openModal");
        const closeBtns = document.querySelectorAll(".close-btn");

        // Avaa ikkuna
        openBtn.onclick = () => modal.style.display = "block";

        // Sulje ikkuna ruksista tai peruuta-namiskasta
        closeBtns.forEach(btn => {
            btn.onclick = () => modal.style.display = "none";
        });
    </script>

</html>