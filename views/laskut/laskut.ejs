<!DOCTYPE html>
<html lang="fi">
<%- include('../partials/head') %>

    <body>
        <div class="content-wrapper">
            <%- include('../partials/header') %>
                <%- include('../partials/nav') %>

                    <main class="container">
                        <div class="page-header">
                            <h2>Laskut</h2>
                            <button id="openModal" class="btn-primary">+ Lisää uusi lasku</button>
                        </div>

                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Tunnus</th>
                                    <th>Asiakas</th>
                                    <th>Työkohde</th>
                                    <th>Päivämäärä</th>
                                    <th>Eräpäivä</th>
                                    <th>Summa</th>
                                    <th>Maksettu</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% laskut.forEach(lasku=> { %>
                                    <tr>
                                        <td><strong>
                                                <%= lasku.lasku_id %>
                                            </strong></td>
                                        <td>
                                            <%= lasku.asiakas_nimi %>
                                        </td>
                                        <td>
                                            <%= lasku.tyokohde_nimi %>
                                        </td>
                                        <td>
                                            <%= lasku.paivamaara.toLocaleDateString() %>
                                        </td>
                                        <td>
                                            <%= lasku.erapvm.toLocaleDateString() %>
                                        </td>
                                        <td>
                                            €<%= lasku.summa.toFixed(2) %>
                                        </td>
                                        <td>
                                            <% if (lasku.maksettu) { %>
                                                Kyllä
                                            <% } else { %>
                                                Ei
                                            <% } %>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </main>
        </div>
        <%- include('../partials/footer') %>
    </body>
<script>
    const modal = document.getElementById("customerModal");
    const openBtn = document.getElementById("openModal");
    const closeBtns = document.querySelectorAll(".close-btn");

    // Avaa ikkuna
    openBtn.onclick = () => modal.style.display = "block";

    // Sulje ikkuna ruksista tai peruuta-namiskasta
    closeBtns.forEach(btn => {
        btn.onclick = () => modal.style.display = "none";
    });
</script>
</html>