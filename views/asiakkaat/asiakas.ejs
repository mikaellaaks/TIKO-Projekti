<!DOCTYPE html>
<html lang="fi">
<%- include('../partials/head') %>

    <body>
        <div class="content-wrapper">
            <%- include('../partials/header') %>
                <%- include('../partials/nav') %>

                    <main class="container">
                        <div class="breadcrumb">
                            <a href="/asiakkaat">← Takaisin listaan</a>
                        </div>

                        <section class="info-card main-form-section">
                            <h2>Muokkaa asiakasta</h2>
                            <form action="/asiakkaat/paivita/<%= asiakas.asiakas_id %>" method="POST">
                                <div class="form-grid">
                                    <div class="form-group">
                                        <label>Nimi</label>
                                        <input type="text" name="nimi" value="<%= asiakas.nimi %>">
                                    </div>
                                    <div class="form-group">
                                        <label>Osoite</label>
                                        <input type="text" name="osoite" value="<%= asiakas.osoite %>">
                                    </div>
                                    <div class="form-group">
                                        <label>Sähköposti</label>
                                        <input type="sahkoposti" name="sahkoposti" value="<%= asiakas.sahkoposti %>">
                                    </div>
                                    <div class="form-group">
                                        <label>Puhelinnumero</label>
                                        <input type="text" name="puhelinnro" value="<%= asiakas.puhelinnro %>">
                                    </div>
                                </div>
                                <div class="form-actions">
                                    <button type="submit" class="btn-primary">Tallenna muutokset</button>
                                </div>
                            </form>
                        </section>

                        <div class="bottom-sections">
                            <section class="data-card">
                                <h3>Avoimet laskut</h3>
                                <p class="muted-text">Ei avoimia laskuja</p>
                            </section>

                            <section class="data-card">
                                <div class="card-header">
                                    <h3>Työkohteet</h3>
                                    <button id="openTyokohdeModal" class="btn-small">+ Lisää työkohde</button>
                                </div>

                                <% if (tyokohteet && tyokohteet.length> 0) { %>
                                    <table class="data-table" style="width: 100%; margin-top: 10px;">
                                        <thead>
                                            <tr>
                                                <th>Tunnus</th>
                                                <th>Nimi</th>
                                                <th>Osoite</th>
                                                <th style="text-align: right;">Toiminnot</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% tyokohteet.forEach(kohde=> { %>
                                                <tr>
                                                    <td>
                                                        <%= kohde.tyokohde_id %>
                                                    </td>
                                                    <td>
                                                        <%= kohde.nimi %>
                                                    </td>
                                                    <td>
                                                        <%= kohde.osoite %>
                                                    </td>
                                                    <td style="text-align: right;">
                                                        <form action="/tyokohteet/poista/<%= kohde.tyokohde_id %>"
                                                            method="POST" style="display: inline;"
                                                            onsubmit="return confirm('Haluatko varmasti poistaa tämän kohteen?')">
                                                            <input type="hidden" name="asiakas_id"
                                                                value="<%= asiakas.asiakas_id %>">
                                                            <button type="submit" class="btn-primary btn-delete">Poista</button>
                                                        </form>
                                                    </td>
                                                </tr>
                                                <% }) %>
                                        </tbody>
                                    </table>
                                    <% } else { %>
                                        <p class="muted-text">Ei rekisteröityjä kohteita tälle asiakkaalle.</p>
                                        <% } %>
                            </section>
                        </div>
                    </main>
        </div>

        <!-- Työkohde Modal -->
        <div id="tyokohdeModal" class="modal">
            <div class="modal-content">
                <div class="modal-header">
                    <h3>Lisää uusi työkohde</h3>
                    <span class="close-btn">&times;</span>
                </div>
                <form action="/tyokohteet/lisaa" method="POST">
                    <input type="hidden" name="asiakas_id" value="<%= asiakas.asiakas_id %>">
                    <div class="form-grid">
                        <div class="form-group">
                            <label>Nimi</label>
                            <input type="text" name="nimi" required>
                        </div>
                        <div class="form-group">
                            <label>Osoite</label>
                            <input type="text" name="osoite" required>
                        </div>
                    </div>
                    <div class="form-actions">
                        <button type="button" class="btn-primary btn-cancel close-btn">Peruuta</button>
                        <button type="submit" class="btn-primary">Tallenna</button>
                    </div>
                </form>
            </div>
        </div>
        <%- include('../partials/footer') %>

            <script>
                const modal = document.getElementById("tyokohdeModal");
                const openBtn = document.getElementById("openTyokohdeModal");
                const closeBtns = document.querySelectorAll(".close-btn");

                openBtn.onclick = () => modal.style.display = "block";
                closeBtns.forEach(btn => {
                    btn.onclick = () => modal.style.display = "none";
                });
            </script>
    </body>

</html>